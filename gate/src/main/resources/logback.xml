<?xml version="1.0" encoding="UTF-8" ?>
<configuration>
    <property name="APPName" value="gate"/>
    <!-- ops.sh 传入 -DLOG_HOME；兼容旧启动（cwd=build/<svc>）时回退 ../logs -->
    <property name="LOGGER_ROOT" value="${LOG_HOME:-../logs}"/>
    <property name="PATTERN" value="%d{yyyy-MM-dd HH:mm:ss.SSS}[%t]%-5level %logger{36}.%M %m%n"/>
    <contextName>${APPName}</contextName>

    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder charset="UTF8">
            <pattern>${PATTERN}</pattern>
        </encoder>
        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <level>INFO</level>
        </filter>
    </appender>

    <appender name="AllLog" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOGGER_ROOT}/${APPName}/%d{yyyy-MM-dd}-%i.log</fileNamePattern>
            <maxHistory>7</maxHistory>
            <totalSizeCap>2GB</totalSizeCap>
            <timeBasedNamingAndTriggeringPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedFNATP">
                <maxFileSize>20MB</maxFileSize>
            </timeBasedNamingAndTriggeringPolicy>
        </rollingPolicy>
        <encoder charset="UTF8">
            <pattern>${PATTERN}</pattern>
        </encoder>
        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <level>DEBUG</level>
        </filter>
    </appender>

    <appender name="ErrorLog" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOGGER_ROOT}/${APPName}/error-%d{yyyy-MM-dd}-%i.log</fileNamePattern>
            <maxHistory>7</maxHistory>
            <totalSizeCap>1GB</totalSizeCap>
            <timeBasedNamingAndTriggeringPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedFNATP">
                <maxFileSize>20MB</maxFileSize>
            </timeBasedNamingAndTriggeringPolicy>
        </rollingPolicy>
        <encoder charset="UTF8">
            <pattern>${PATTERN}</pattern>
        </encoder>
        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <level>ERROR</level>
        </filter>
    </appender>

    <!-- 业务包写详细 DEBUG；第三方降噪 -->
    <logger name="gate" level="DEBUG"/>
    <logger name="utils" level="DEBUG"/>
    <logger name="net" level="DEBUG"/>
    <logger name="tool" level="DEBUG"/>
    <logger name="io.netty" level="INFO"/>
    <logger name="org.sqlite" level="INFO"/>

    <root level="INFO">
        <appender-ref ref="STDOUT"/>
        <appender-ref ref="AllLog"/>
        <appender-ref ref="ErrorLog"/>
    </root>
</configuration>
